{
  "name": "ecom",
  "version": "1.0.0",
  "type": "module",
  "description": "ecommerce rest api",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "server": "nodemon server.js",
    "client": "npm start --prefix ./client",
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "sonarqube": "sonar-scanner",
    "test": "npm run test:backend && npm run test:frontend && npm run test:backend-integration && npm run test:frontend-integration",
    "test:frontend": "node --experimental-vm-modules node_modules/jest/bin/jest.js --config jest.frontend.config.js",
    "test:sonar": "node --experimental-vm-modules node_modules/jest/bin/jest.js --config jest.sonar.config.js --runInBand",
    "test:backend": "node --experimental-vm-modules node_modules/jest/bin/jest.js --config jest.backend.config.js",
    "test:backend-integration": "node --experimental-vm-modules node_modules/jest/bin/jest.js --config jest.backend.integration.config.js",
    "test:frontend-integration": "node --experimental-vm-modules node_modules/jest/bin/jest.js --config jest.frontend.integration.config.js",
    "test:sast": "node --experimental-vm-modules node_modules/jest/bin/jest.js --config jest.sast.config.js",
    "test:dast": "node --experimental-vm-modules node_modules/jest/bin/jest.js --config jest.dast.config.js --runInBand",
    "test:security": "npm run test:sast && npm run test:dast",
    "test:unit": "npm run test:backend && npm run test:frontend",
    "test:integration": "npm run test:backend-integration && npm run test:frontend-integration",
    "test:performance:stress": "node __tests__/performance/stress/scripts/runAllStressFlows.js",
    "test:performance:stress:auth": "node __tests__/performance/stress/scripts/runStressFlow.js auth",
    "test:performance:stress:browsing": "node __tests__/performance/stress/scripts/runStressFlow.js browsing",
    "test:performance:stress:orders": "node __tests__/performance/stress/scripts/runStressFlow.js orders",
    "test:performance:stress:payment": "node __tests__/performance/stress/scripts/runStressFlow.js payment"
  },
  "keywords": [],
  "author": "RP",
  "license": "ISC",
  "dependencies": {
    "bcrypt": "^6.0.0",
    "braintree": "^3.22.0",
    "colors": "^1.4.0",
    "concurrently": "^9.2.1",
    "cors": "^2.8.5",
    "date-fns": "^3.3.1",
    "dotenv": "^16.4.1",
    "express": "^5.2.1",
    "express-formidable": "^1.2.0",
    "express-mongo-sanitize": "^2.2.0",
    "express-rate-limit": "^8.3.2",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "mockingoose": "^2.16.2",
    "mongodb": "^6.3.0",
    "mongoose": "^8.1.2",
    "morgan": "^1.10.1",
    "nodemon": "^3.1.14",
    "prettier": "@bokub/prettier-config",
    "react-icons": "^5.0.1",
    "slugify": "^1.6.6"
  },
  "devDependencies": {
    "@babel/core": "^7.24.5",
    "@babel/preset-env": "^7.24.5",
    "@babel/preset-react": "^7.24.1",
    "@bokub/prettier-config": "^2.1.0",
    "@playwright/test": "^1.44.0",
    "@types/node": "^20.12.12",
    "babel-jest": "^29.7.0",
    "identity-obj-proxy": "^3.0.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "mongodb-memory-server": "^11.0.1",
    "sonarqube-scanner": "^4.3.4",
    "supertest": "^7.2.2"
  },
  "overrides": {
    "picomatch": "2.3.2"
  }
}
